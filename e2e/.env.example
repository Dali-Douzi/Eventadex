# Copy to .env and fill in values

# Running servers
MASTER_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
USER_URL=http://localhost:3002
API_URL=http://localhost:5000

# Master admin credentials (must exist in your DB)
MASTER_EMAIL=master@example.com
MASTER_PASSWORD=yourpassword

# The E2E test org will be created by globalSetup with these credentials
E2E_ORG_EMAIL=e2e@playwright-test.com
E2E_ORG_PASSWORD=E2ePlaywright!99
E2E_ORG_SLUG=e2e-playwright
