# ══════════════════════════════════════════════════════════════════════════════
# Eventadex — Production Environment Variables
# Copy this file to .env and fill in every value before starting the server.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────

# TCP port the Express server listens on (default: 5000)
PORT=5000

# Node environment — must be "production" in prod to suppress debug output
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────

# Full MongoDB connection string.
# When running via Docker Compose, use the service name as the host:
#   mongodb://mongodb:27017/event-registration
# For Atlas:
#   mongodb+srv://<user>:<pass>@cluster.mongodb.net/event-registration?retryWrites=true&w=majority
MONGO_URI=mongodb://mongodb:27017/event-registration

# ── Authentication ────────────────────────────────────────────────────────────

# Secret key used to sign JWT tokens — use a long random string (min 32 chars)
JWT_SECRET=replace_with_a_long_random_string_min_32_chars

# Token expiry (e.g. "7d", "24h", "1h")
JWT_EXPIRES_IN=7d

# ── CORS — allowed origins ────────────────────────────────────────────────────

# URL where the Platform Admin app is served
CLIENT_MASTER_URL=http://localhost:3000

# URL where the Event Admin app is served
CLIENT_ADMIN_URL=http://localhost:3001

# URL where the Attendee Registration app is served
CLIENT_USER_URL=http://localhost:3002

# ── Stripe (optional — only needed when paymentEnabled = true for any event) ──

# Stripe secret key (sk_live_... for production, sk_test_... for testing)
STRIPE_SECRET_KEY=sk_live_replace_with_your_stripe_secret_key

# ── reCAPTCHA (required for the attendee registration form) ──────────────────

# Google reCAPTCHA v2 secret key
RECAPTCHA_SECRET_KEY=replace_with_your_recaptcha_secret_key

# ── Email (Nodemailer) ────────────────────────────────────────────────────────

# SMTP host (e.g. smtp.sendgrid.net, smtp.mailgun.org, smtp.gmail.com)
EMAIL_HOST=smtp.example.com

# SMTP port (587 for STARTTLS, 465 for SSL/TLS)
EMAIL_PORT=587

# Set to "true" if using port 465 (SSL), leave empty or "false" for STARTTLS
EMAIL_SECURE=false

# SMTP authentication
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password

# "From" address that appears in confirmation emails
EMAIL_FROM=noreply@yourdomain.com
