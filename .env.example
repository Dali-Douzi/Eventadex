# MongoDB
MONGO_URI=mongodb://localhost:27017/event-registration

# Auth
JWT_SECRET=your_jwt_secret_here

# Master seed (used by npm run seed:master)
MASTER_NAME=Platform Master
MASTER_EMAIL=master@example.com
MASTER_PASSWORD=changeme123

# Server
PORT=5000

# Client origins
CLIENT_MASTER_URL=http://localhost:3000
CLIENT_ADMIN_URL=http://localhost:3001
CLIENT_USER_URL=http://localhost:3002

# Email (e.g. Gmail SMTP or SendGrid)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password_or_app_password
EMAIL_FROM=noreply@yourdomain.com

# Cloudinary (required for image uploads — sign up free at cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Moyasar (required when paymentEnabled = true for any event)
MOYASAR_SECRET_KEY=sk_test_replace_with_your_moyasar_secret_key

# Google reCAPTCHA v2 (required for registration form)
RECAPTCHA_SECRET_KEY=replace_with_your_recaptcha_secret_key
